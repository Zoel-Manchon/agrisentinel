        "type": "query",
        "datasource": {
          "type": "influxdb",
          "uid": "${DS_INFLUXDB}"
        },
        "definition": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"agri\", tag: \"device_id\")",
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"agri\", tag: \"device_id\")",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
