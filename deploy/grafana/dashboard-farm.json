    {
      "id": 33,
      "type": "stat",
      "title": "🌡 Node health — seconds since last telemetry",
      "description": "Seconds since each node's last telemetry point. Green = fresh · yellow > 90s · red > 180s (node likely down). Filtered by the $node variable.",
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "red",
                "value": 180
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
