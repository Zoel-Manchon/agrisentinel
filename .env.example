# Copy to .env for any local overrides. .env is git-ignored — never commit real
# secrets. The demo runs entirely on local-dev placeholders below.

# InfluxDB (matches deploy/docker-compose.yml)
INFLUXDB_ORG=agri
INFLUXDB_BUCKET=agri
INFLUXDB_TOKEN=agri-local-dev-token

# MQTT broker
MQTT_HOST=localhost
MQTT_PORT=1883

# HMAC signing key for the node fleet (demo value; provision per-node in prod)
AGRI_HMAC_KEY=agrisentinel-demo-key-node-fleet-01
