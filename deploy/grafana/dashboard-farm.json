          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"agri\")\n  |> range(start: -6h)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.device_id =~ /${node:regex}/)\n  |> group(columns: [\"device_id\"])\n  |> max(column: \"_time\")\n  |> map(fn: (r) => ({ device_id: r.device_id, _value: (float(v: uint(v: now())) - float(v: uint(v: r._time))) / 1000000000.0 }))\n  |> group()\n  |> keep(columns: [\"device_id\", \"_value\"])"
        }
      ]
    }
